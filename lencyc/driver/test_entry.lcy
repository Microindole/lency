// lencyc/driver/test_entry.lcy
// Self-host lencyc lexer/parser test entry.

import std.core
import std.fs
import std.convert
import std.str
import lencyc.driver.test_cases
import lencyc.syntax.lexer
import lencyc.syntax.parser
import lencyc.syntax.ast
import lencyc.sema.resolver

bool expect_parse_error(string source, string label) {
    var parser = make_parser(source)
    var stmts = parser.parse()
    if !parser.has_error {
        print("Invalid test failed: " + label + " should be rejected.\n")
        return false
    }
    print("Invalid test passed: " + label + " rejected (" + int_to_string(stmts.len()) + " stmt).\n")
    return true
}

bool expect_resolve_error(string source, string label) {
    var parser = make_parser(source)
    var stmts = parser.parse()
    if parser.has_error {
        print("Resolve test setup failed: parser rejected source for " + label + ".\n")
        return false
    }
    var result = resolve_statements(stmts)
    if !result.has_error {
        print("Resolve negative test failed: " + label + " should produce resolver error.\n")
        return false
    }
    print("Resolve negative test passed: " + label + " (" + int_to_string(result.error_count) + " errors).\n")
    return true
}

bool expect_resolve_success(string source, string label) {
    var parser = make_parser(source)
    var stmts = parser.parse()
    if parser.has_error {
        print("Resolve test setup failed: parser rejected source for " + label + ".\n")
        return false
    }
    var result = resolve_statements(stmts)
    if result.has_error {
        print("Resolve positive test failed: " + label + " should pass.\n")
        return false
    }
    print("Resolve positive test passed: " + label + ".\n")
    return true
}

bool expect_function_body_resolve_error(Vec<string> params, string source, string label) {
    var parser = make_parser(source)
    var body = parser.parse()
    if parser.has_error {
        print("Function-body resolve test setup failed: parser rejected source for " + label + ".\n")
        return false
    }
    var result = resolve_function_body(params, body)
    if !result.has_error {
        print("Function-body negative test failed: " + label + " should produce resolver error.\n")
        return false
    }
    print("Function-body negative test passed: " + label + " (" + int_to_string(result.error_count) + " errors).\n")
    return true
}

bool expect_function_body_resolve_success(Vec<string> params, string source, string label) {
    var parser = make_parser(source)
    var body = parser.parse()
    if parser.has_error {
        print("Function-body resolve test setup failed: parser rejected source for " + label + ".\n")
        return false
    }
    var result = resolve_function_body(params, body)
    if result.has_error {
        print("Function-body positive test failed: " + label + " should pass.\n")
        return false
    }
    print("Function-body positive test passed: " + label + ".\n")
    return true
}

int main() {
    print("Running Lency Self-hosted Compiler Lexer/Parser Tests...\n")
    
    // 读取自身的 Token 定义文件作为测试输入
    var path = "lencyc/syntax/token.lcy"
    print("Reading test file: " + path + "\n")
    
    var source_res = read_to_string(path)
    if source_res.is_err() {
        print("Failed to read file: " + path + "\n")
        return 1
    }
    var source = source_res.unwrap()
    
    print("Step 1: Lexing test...\n")
    var lexer = make_lexer(source)
    var count = 0
    while true {
        var token = lexer.scan_token()
        count = count + 1
        if token.kind == 0 { // T_EOF
            break
        }
        if token.kind == 1 { // T_ERROR
            print("Lexer error at line " + int_to_string(token.line) + "\n")
            return 1
        }
    }
    print("Successfully lexed " + int_to_string(count) + " tokens.\n")
    
    print("Step 2: Parsing test...\n")
    var simple_source = src_valid_main_program()
    var parser = make_parser(simple_source)
    var statements = parser.parse()
    
    if parser.has_error {
        print("Parsing failed!\n")
        return 1
    }
    
    print("Successfully parsed " + int_to_string(statements.len()) + " statements.\n")
    var i = 0
    while i < statements.len() {
        print("AST[" + int_to_string(i) + "]: " + stmt_to_string(statements[i]) + "\n")
        i = i + 1
    }

    print("Step 3: Invalid placement tests...\n")
    if !expect_parse_error(src_invalid_break_top_level(), "top-level break") {
        return 1
    }
    if !expect_parse_error(src_invalid_continue_top_level(), "top-level continue") {
        return 1
    }

    print("Step 4: Invalid for syntax tests...\n")
    if !expect_parse_error(src_invalid_for_missing_first_semicolon_expr_init(), "for missing first semicolon") {
        return 1
    }
    if !expect_parse_error(src_invalid_for_missing_first_semicolon_var_init(), "for(var) missing first semicolon") {
        return 1
    }
    if !expect_parse_error(src_invalid_for_missing_second_semicolon(), "for missing second semicolon") {
        return 1
    }
    if !expect_parse_error(src_invalid_for_missing_left_brace(), "for missing left brace") {
        return 1
    }
    if !expect_parse_error(src_invalid_unterminated_string_literal(), "unterminated string literal") {
        return 1
    }
    if !expect_parse_error(src_invalid_float_missing_fraction_digits(), "float missing fraction digits") {
        return 1
    }
    var recovery_source = src_parser_recovery_invalid_then_valid()
    var recovery_parser = make_parser(recovery_source)
    var recovery_stmts = recovery_parser.parse()
    if !recovery_parser.has_error {
        print("Parser recovery test failed: expected parse error for invalid prefix.\n")
        return 1
    }
    if recovery_stmts.len() < 2 {
        print("Parser recovery test failed: expected parser to continue after recovery.\n")
        return 1
    }
    print("Parser recovery test passed: parser continued after first error.\n")

    print("Step 5: Call/member parsing tests...\n")
    var call_member_source = src_call_member_program()
    var call_member_parser = make_parser(call_member_source)
    var call_member_stmts = call_member_parser.parse()
    if call_member_parser.has_error {
        print("Call/member parse failed unexpectedly.\n")
        return 1
    }
    print("Call/member AST[1]: " + stmt_to_string(call_member_stmts[1]) + "\n")
    print("Call/member AST[2]: " + stmt_to_string(call_member_stmts[2]) + "\n")
    if !contains(stmt_to_string(call_member_stmts[1]), "(call foo obj 2)") {
        print("Call expression AST shape mismatch.\n")
        return 1
    }
    if !contains(stmt_to_string(call_member_stmts[2]), "(call (get obj.to_string))") {
        print("Member call AST shape mismatch.\n")
        return 1
    }

    print("Step 6: String literal parsing tests...\n")
    var string_source = src_string_literal_program()
    var string_parser = make_parser(string_source)
    var string_stmts = string_parser.parse()
    if string_parser.has_error {
        print("String literal parse failed unexpectedly.\n")
        return 1
    }
    if !contains(stmt_to_string(string_stmts[0]), "(var msg = \"hello\")") {
        print("String literal var AST shape mismatch.\n")
        return 1
    }
    if !contains(stmt_to_string(string_stmts[2]), "(call print \"done\")") {
        print("String literal call AST shape mismatch.\n")
        return 1
    }

    print("Step 7: Float literal parsing tests...\n")
    var float_source = src_float_literal_program()
    var float_parser = make_parser(float_source)
    var float_stmts = float_parser.parse()
    if float_parser.has_error {
        print("Float literal parse failed unexpectedly.\n")
        return 1
    }
    if !contains(stmt_to_string(float_stmts[0]), "(var pi = 3.14)") {
        print("Float literal var AST shape mismatch.\n")
        return 1
    }
    if !contains(stmt_to_string(float_stmts[2]), "(call print (+ pi half))") {
        print("Float literal expression AST shape mismatch.\n")
        return 1
    }

    print("Step 8: Scientific notation parsing tests...\n")
    var scientific_source = src_scientific_number_program()
    var scientific_parser = make_parser(scientific_source)
    var scientific_stmts = scientific_parser.parse()
    if scientific_parser.has_error {
        print("Scientific notation parse failed unexpectedly.\n")
        return 1
    }
    if !contains(stmt_to_string(scientific_stmts[0]), "(var av = 1.23e-4)") {
        print("Scientific notation AST shape mismatch (av).\n")
        return 1
    }
    if !contains(stmt_to_string(scientific_stmts[1]), "(var bv = 9E+2)") {
        print("Scientific notation AST shape mismatch (bv).\n")
        return 1
    }

    print("Step 9: Escaped string and char literal parsing tests...\n")
    var escape_source = src_string_escape_program()
    var escape_parser = make_parser(escape_source)
    var escape_stmts = escape_parser.parse()
    if escape_parser.has_error {
        print("Escaped string parse failed unexpectedly.\n")
        return 1
    }
    if !contains(stmt_to_string(escape_stmts[0]), "(var msg = \"he said \\\"ok\\\"\")") {
        print("Escaped string AST shape mismatch.\n")
        return 1
    }

    var char_source = src_char_literal_program()
    var char_parser = make_parser(char_source)
    var char_stmts = char_parser.parse()
    if char_parser.has_error {
        print("Char literal parse failed unexpectedly.\n")
        return 1
    }
    if !contains(stmt_to_string(char_stmts[0]), "(var ch = 'a')") {
        print("Char literal AST shape mismatch.\n")
        return 1
    }

    print("Step 10: Nested loop rewrite safety tests...\n")
    var nested_source = src_nested_loop_continue_safety()
    var nested_parser = make_parser(nested_source)
    var nested_stmts = nested_parser.parse()
    if nested_parser.has_error {
        print("Nested loop parse failed unexpectedly.\n")
        return 1
    }
    if nested_stmts.len() == 0 {
        print("Nested loop parse produced empty AST.\n")
        return 1
    }
    var nested_ast = stmt_to_string(nested_stmts[0])
    print("Nested AST[0]: " + nested_ast + "\n")
    if !contains(nested_ast, "(while (< i 3) [(continue)])") {
        print("Nested loop safety failed: inner while continue was rewritten unexpectedly.\n")
        return 1
    }
    if !contains(nested_ast, "(block [(expr (assign i (+ i 1))), (continue)])") {
        print("Nested loop safety failed: outer for continue did not inject increment.\n")
        return 1
    }

    print("Step 11: Name resolution smoke test...\n")
    var resolve_result = resolve_statements(statements)
    if resolve_result.has_error {
        print("Resolver failed unexpectedly on valid sample.\n")
        return 1
    }
    print("Resolver smoke test passed.\n")

    print("Step 12: Name resolution negative tests...\n")
    if !expect_resolve_error(src_resolver_undefined_in_initializer(), "undefined variable in initializer") {
        return 1
    }
    if !expect_resolve_error(src_resolver_undefined_assignment(), "assignment to undefined variable") {
        return 1
    }
    if !expect_resolve_error(src_resolver_duplicate_same_scope(), "duplicate variable in same scope") {
        return 1
    }
    if !expect_resolve_error(src_resolver_out_of_scope_after_block(), "variable out of scope after block") {
        return 1
    }

    print("Step 13: Name resolution positive scope tests...\n")
    if !expect_resolve_success(src_resolver_shadowing_ok(), "shadowing in inner block is legal") {
        return 1
    }

    print("Step 14: Function-like scope resolution tests...\n")
    var fn_params = vec!["p"]
    if !expect_function_body_resolve_success(fn_params, src_resolver_function_body_ok(), "function-like scope resolution") {
        return 1
    }
    if !expect_function_body_resolve_success(fn_params, src_resolver_function_body_if_else_return_ok(), "if-else guaranteed return is legal") {
        return 1
    }
    if !expect_function_body_resolve_error(fn_params, src_resolver_function_body_missing_return(), "function body missing return") {
        return 1
    }
    if !expect_function_body_resolve_error(fn_params, src_resolver_function_body_void_return_bad(), "void return in value-return function") {
        return 1
    }

    print("Step 15: Builtin call arity resolution tests...\n")
    if !expect_resolve_success(src_resolver_builtin_arity_ok(), "builtin arity positive") {
        return 1
    }
    if !expect_resolve_error(src_resolver_builtin_arity_bad(), "builtin arity mismatch negative") {
        return 1
    }

    print("Step 16: Type consistency resolution tests...\n")
    if !expect_resolve_success(src_resolver_type_consistency_ok(), "type consistency positive") {
        return 1
    }
    if !expect_resolve_error(src_resolver_type_assignment_bad(), "assignment type mismatch negative") {
        return 1
    }
    if !expect_resolve_error(src_resolver_type_arithmetic_bad(), "arithmetic type mismatch negative") {
        return 1
    }
    if !expect_resolve_error(src_resolver_type_logical_bad(), "logical type mismatch negative") {
        return 1
    }

    print("Step 17: User function call arity resolution tests...\n")
    if !expect_resolve_success(src_resolver_user_function_arity_ok(), "user function arity positive") {
        return 1
    }
    if !expect_resolve_error(src_resolver_user_function_arity_bad(), "user function arity mismatch negative") {
        return 1
    }

    print("Step 18: User function type-signature resolution tests...\n")
    if !expect_resolve_success(src_resolver_user_function_type_ok(), "user function type signature positive") {
        return 1
    }
    if !expect_resolve_success(src_resolver_user_function_float_signature_ok(), "user function float signature positive") {
        return 1
    }
    if !expect_resolve_error(src_resolver_user_function_arg_type_bad(), "user function argument type mismatch negative") {
        return 1
    }
    if !expect_resolve_error(src_resolver_user_function_return_type_bad(), "user function return type mismatch negative") {
        return 1
    }

    print("Step 19: Custom type signature resolution tests...\n")
    if !expect_resolve_success(src_resolver_custom_type_signature_ok(), "custom type signature positive") {
        return 1
    }
    if !expect_resolve_error(src_resolver_custom_type_signature_bad(), "custom type signature unknown type negative") {
        return 1
    }

    print("Step 20: Type declaration skeleton tests...\n")
    var struct_source = src_parser_struct_decl_program()
    var struct_parser = make_parser(struct_source)
    var struct_stmts = struct_parser.parse()
    if struct_parser.has_error {
        print("Type declaration parse failed unexpectedly.\n")
        return 1
    }
    if struct_stmts.len() < 1 || !contains(stmt_to_string(struct_stmts[0]), "(struct Boxed)") {
        print("Type declaration AST shape mismatch.\n")
        return 1
    }
    if !expect_resolve_success(src_resolver_custom_type_signature_with_struct_ok(), "custom type signature with type declaration positive") {
        return 1
    }

    print("Step 21: Impl declaration skeleton tests...\n")
    var impl_source = src_parser_impl_decl_program()
    var impl_parser = make_parser(impl_source)
    var impl_stmts = impl_parser.parse()
    if impl_parser.has_error {
        print("Impl declaration parse failed unexpectedly.\n")
        return 1
    }
    if impl_stmts.len() < 2 || !contains(stmt_to_string(impl_stmts[1]), "(impl Boxed ") {
        print("Impl declaration AST shape mismatch.\n")
        return 1
    }
    if !expect_resolve_success(src_resolver_custom_type_signature_with_impl_ok(), "custom type signature with impl declaration positive") {
        return 1
    }

    print("Step 22: Impl member function skeleton parsing tests...\n")
    var impl_method_source = src_parser_impl_method_decl_program()
    var impl_method_parser = make_parser(impl_method_source)
    var impl_method_stmts = impl_method_parser.parse()
    if impl_method_parser.has_error {
        print("Impl member function parse failed unexpectedly.\n")
        return 1
    }
    if impl_method_stmts.len() < 2 {
        print("Impl member function AST size mismatch.\n")
        return 1
    }
    var impl_ast = stmt_to_string(impl_method_stmts[1])
    if !contains(impl_ast, "(impl Boxed ") || !contains(impl_ast, "(func value/0") {
        print("Impl member function AST shape mismatch.\n")
        return 1
    }

    print("Step 23: Impl semantic resolution tests...\n")
    if !expect_resolve_success(src_resolver_impl_methods_ok(), "impl method semantic positive") {
        return 1
    }
    if !expect_resolve_error(src_resolver_impl_unknown_type_bad(), "impl unknown target type negative") {
        return 1
    }
    if !expect_resolve_error(src_resolver_impl_duplicate_method_bad(), "impl duplicate method negative") {
        return 1
    }

    print("Tests completed successfully.\n")
    return 0
}
