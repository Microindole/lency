// lencyc/driver/test_entry.lcy
// 自举版 Lency 编译器的词法与语法测试入口

import std.core
import std.fs
import std.convert
import std.str
import lencyc.driver.test_cases
import lencyc.syntax.lexer
import lencyc.syntax.parser
import lencyc.syntax.ast
import lencyc.sema.resolver

bool expect_parse_error(string source, string label) {
    var parser = make_parser(source)
    var stmts = parser.parse()
    if !parser.has_error {
        print("Invalid test failed: " + label + " should be rejected.\n")
        return false
    }
    print("Invalid test passed: " + label + " rejected (" + int_to_string(stmts.len()) + " stmt).\n")
    return true
}

bool expect_resolve_error(string source, string label) {
    var parser = make_parser(source)
    var stmts = parser.parse()
    if parser.has_error {
        print("Resolve test setup failed: parser rejected source for " + label + ".\n")
        return false
    }
    var result = resolve_statements(stmts)
    if !result.has_error {
        print("Resolve negative test failed: " + label + " should produce resolver error.\n")
        return false
    }
    print("Resolve negative test passed: " + label + " (" + int_to_string(result.error_count) + " errors).\n")
    return true
}

bool expect_resolve_success(string source, string label) {
    var parser = make_parser(source)
    var stmts = parser.parse()
    if parser.has_error {
        print("Resolve test setup failed: parser rejected source for " + label + ".\n")
        return false
    }
    var result = resolve_statements(stmts)
    if result.has_error {
        print("Resolve positive test failed: " + label + " should pass.\n")
        return false
    }
    print("Resolve positive test passed: " + label + ".\n")
    return true
}

int main() {
    print("Running Lency Self-hosted Compiler Lexer/Parser Tests...\n")
    
    // 读取自身的 Token 定义文件作为测试输入
    var path = "lencyc/syntax/token.lcy"
    print("Reading test file: " + path + "\n")
    
    var source_res = read_to_string(path)
    if source_res.is_err() {
        print("Failed to read file: " + path + "\n")
        return 1
    }
    var source = source_res.unwrap()
    
    print("Step 1: Lexing test...\n")
    var lexer = make_lexer(source)
    var count = 0
    while true {
        var token = lexer.scan_token()
        count = count + 1
        if token.kind == 0 { // T_EOF
            break
        }
        if token.kind == 1 { // T_ERROR
            print("Lexer error at line " + int_to_string(token.line) + "\n")
            return 1
        }
    }
    print("Successfully lexed " + int_to_string(count) + " tokens.\n")
    
    print("Step 2: Parsing test...\n")
    var simple_source = src_valid_main_program()
    var parser = make_parser(simple_source)
    var statements = parser.parse()
    
    if parser.has_error {
        print("Parsing failed!\n")
        return 1
    }
    
    print("Successfully parsed " + int_to_string(statements.len()) + " statements.\n")
    var i = 0
    while i < statements.len() {
        print("AST[" + int_to_string(i) + "]: " + stmt_to_string(statements[i]) + "\n")
        i = i + 1
    }

    print("Step 3: Invalid placement tests...\n")
    if !expect_parse_error(src_invalid_break_top_level(), "top-level break") {
        return 1
    }
    if !expect_parse_error(src_invalid_continue_top_level(), "top-level continue") {
        return 1
    }

    print("Step 4: Invalid for syntax tests...\n")
    if !expect_parse_error(src_invalid_for_missing_first_semicolon_expr_init(), "for missing first semicolon") {
        return 1
    }
    if !expect_parse_error(src_invalid_for_missing_first_semicolon_var_init(), "for(var) missing first semicolon") {
        return 1
    }
    if !expect_parse_error(src_invalid_for_missing_second_semicolon(), "for missing second semicolon") {
        return 1
    }
    if !expect_parse_error(src_invalid_for_missing_left_brace(), "for missing left brace") {
        return 1
    }
    if !expect_parse_error(src_invalid_unterminated_string_literal(), "unterminated string literal") {
        return 1
    }
    if !expect_parse_error(src_invalid_float_missing_fraction_digits(), "float missing fraction digits") {
        return 1
    }

    print("Step 5: Call/member parsing tests...\n")
    var call_member_source = src_call_member_program()
    var call_member_parser = make_parser(call_member_source)
    var call_member_stmts = call_member_parser.parse()
    if call_member_parser.has_error {
        print("Call/member parse failed unexpectedly.\n")
        return 1
    }
    print("Call/member AST[1]: " + stmt_to_string(call_member_stmts[1]) + "\n")
    print("Call/member AST[2]: " + stmt_to_string(call_member_stmts[2]) + "\n")
    if !contains(stmt_to_string(call_member_stmts[1]), "(call foo obj 2)") {
        print("Call expression AST shape mismatch.\n")
        return 1
    }
    if !contains(stmt_to_string(call_member_stmts[2]), "(call (get obj.to_string))") {
        print("Member call AST shape mismatch.\n")
        return 1
    }

    print("Step 6: String literal parsing tests...\n")
    var string_source = src_string_literal_program()
    var string_parser = make_parser(string_source)
    var string_stmts = string_parser.parse()
    if string_parser.has_error {
        print("String literal parse failed unexpectedly.\n")
        return 1
    }
    if !contains(stmt_to_string(string_stmts[0]), "(var msg = \"hello\")") {
        print("String literal var AST shape mismatch.\n")
        return 1
    }
    if !contains(stmt_to_string(string_stmts[2]), "(call print \"done\")") {
        print("String literal call AST shape mismatch.\n")
        return 1
    }

    print("Step 7: Float literal parsing tests...\n")
    var float_source = src_float_literal_program()
    var float_parser = make_parser(float_source)
    var float_stmts = float_parser.parse()
    if float_parser.has_error {
        print("Float literal parse failed unexpectedly.\n")
        return 1
    }
    if !contains(stmt_to_string(float_stmts[0]), "(var pi = 3.14)") {
        print("Float literal var AST shape mismatch.\n")
        return 1
    }
    if !contains(stmt_to_string(float_stmts[2]), "(call print (+ pi half))") {
        print("Float literal expression AST shape mismatch.\n")
        return 1
    }

    print("Step 8: Nested loop rewrite safety tests...\n")
    var nested_source = src_nested_loop_continue_safety()
    var nested_parser = make_parser(nested_source)
    var nested_stmts = nested_parser.parse()
    if nested_parser.has_error {
        print("Nested loop parse failed unexpectedly.\n")
        return 1
    }
    if nested_stmts.len() == 0 {
        print("Nested loop parse produced empty AST.\n")
        return 1
    }
    var nested_ast = stmt_to_string(nested_stmts[0])
    print("Nested AST[0]: " + nested_ast + "\n")
    if !contains(nested_ast, "(while (< i 3) [(continue)])") {
        print("Nested loop safety failed: inner while continue was rewritten unexpectedly.\n")
        return 1
    }
    if !contains(nested_ast, "(block [(expr (assign i (+ i 1))), (continue)])") {
        print("Nested loop safety failed: outer for continue did not inject increment.\n")
        return 1
    }

    print("Step 9: Name resolution smoke test...\n")
    var resolve_result = resolve_statements(statements)
    if resolve_result.has_error {
        print("Resolver failed unexpectedly on valid sample.\n")
        return 1
    }
    print("Resolver smoke test passed.\n")

    print("Step 10: Name resolution negative tests...\n")
    if !expect_resolve_error(src_resolver_undefined_in_initializer(), "undefined variable in initializer") {
        return 1
    }
    if !expect_resolve_error(src_resolver_undefined_assignment(), "assignment to undefined variable") {
        return 1
    }
    if !expect_resolve_error(src_resolver_duplicate_same_scope(), "duplicate variable in same scope") {
        return 1
    }
    if !expect_resolve_error(src_resolver_out_of_scope_after_block(), "variable out of scope after block") {
        return 1
    }

    print("Step 11: Name resolution positive scope tests...\n")
    if !expect_resolve_success(src_resolver_shadowing_ok(), "shadowing in inner block is legal") {
        return 1
    }

    print("Step 12: Function-like scope resolution tests...\n")
    var fn_body_parser = make_parser(src_resolver_function_body_ok())
    var fn_body = fn_body_parser.parse()
    if fn_body_parser.has_error {
        print("Function-like resolve test setup parse failed.\n")
        return 1
    }
    var fn_params = vec!["p"]
    var fn_result = resolve_function_body(fn_params, fn_body)
    if fn_result.has_error {
        print("Function-like scope resolution should pass but failed.\n")
        return 1
    }
    print("Function-like scope resolution passed.\n")

    print("Tests completed successfully.\n")
    return 0
}
