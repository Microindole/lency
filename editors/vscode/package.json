{
    "name": "lency-lang",
    "displayName": "Lency Professional Support",
    "description": "Professional industrial-grade support for Lency language (.lcy)",
    "version": "0.7.0",
    "publisher": "lency",
    "icon": "media/icon.png",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/Microindole/lency.git"
    },
    "main": "./dist/extension.js",
    "scripts": {
        "build": "tsc -p .",
        "watch": "tsc -watch -p .",
        "test": "tsc -p . && node dist/test/index.js",
        "package:vsix": "npm run build && npx @vscode/vsce package",
        "dev:ide": "node ../scripts/dev_ide.mjs",
        "dev:ide:check": "node ../scripts/dev_ide.mjs --check-only",
        "check:editor": "npm run build && node dist/test/index.js",
        "check:all:fast": "npm run check:editor && node ../scripts/dev_ide.mjs --check-only --skip-install && node ../scripts/run_python_checks.mjs",
        "check:all": "npm ci --cache ../.npm-cache && npm run check:all:fast",
        "check:all:ci": "npm run check:all"
    },
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "dependencies": {
        "vscode-languageclient": "^9.0.1"
    },
    "devDependencies": {
        "@types/vscode": "^1.75.0",
        "@types/node": "^25.5.0",
        "typescript": "^6.0.2"
    },
    "contributes": {
        "configuration": {
            "title": "Lency",
            "properties": {
                "lency.serverPath": {
                    "type": "string",
                    "default": "",
                    "description": "Path to lency_ls executable. Supports ${workspaceFolder}. Empty means auto-detect under target/{debug,release}/lency_ls(.exe on Windows)."
                }
            }
        },
        "languages": [
            {
                "id": "lency",
                "aliases": [
                    "Lency",
                    "lency"
                ],
                "extensions": [
                    ".lcy"
                ],
                "icon": {
                    "light": "./media/file-light.png",
                    "dark": "./media/file-dark.png"
                },
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "lency",
                "scopeName": "source.lcy",
                "path": "./syntaxes/lency.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "lency",
                "path": "./snippets/lency.code-snippets"
            }
        ],
        "problemMatchers": [
            {
                "name": "lency",
                "owner": "lency",
                "fileLocation": [
                    "relative",
                    "${workspaceFolder}"
                ],
                "pattern": {
                    "regexp": "^(error|warning):\\s+(.*):(\\d+):(\\d+):\\s+(.*)$",
                    "file": 2,
                    "line": 3,
                    "column": 4,
                    "message": 5
                }
            }
        ]
    }
}
