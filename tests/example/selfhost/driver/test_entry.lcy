// tests/example/selfhost/driver/test_entry.lcy
// Self-host lencyc lexer/parser test entry.

import std.core
import std.fs
import std.convert
import std.str
import tests.example.selfhost.driver.test_cases
import tests.example.selfhost.driver.steps.const_step
import tests.example.selfhost.driver.steps.enum_step
import tests.example.selfhost.driver.steps.import_extern
import tests.example.selfhost.driver.steps.match_expr
import tests.example.selfhost.driver.steps.parser_frontend
import tests.example.selfhost.driver.steps.signature
import tests.example.selfhost.driver.steps.structs
import tests.example.selfhost.driver.test_support
import lencyc.syntax.lexer
import lencyc.syntax.parser
import lencyc.syntax.ast
import lencyc.syntax.token
import lencyc.sema.resolver

int main() {
    print("Running Lency Self-hosted Compiler Lexer/Parser Tests...\n")
    
    // 读取自身的 Token 定义文件作为测试输入
    var path = "lencyc/syntax/token.lcy"
    print("Reading test file: " + path + "\n")
    
    var source_res = read_to_string(path)
    if source_res.is_err() {
        print("Failed to read file: " + path + "\n")
        return 1
    }
    var source = source_res.unwrap()
    
    print("Step 1: Lexing test...\n")
    var lexer = make_lexer(source)
    var count = 0
    while true {
        var token = lexer.scan_token()
        count = count + 1
        if token.kind == 0 { // T_EOF
            break
        }
        if token.kind == 1 { // T_ERROR
            print("Lexer error at line " + int_to_string(token.line) + "\n")
            return 1
        }
    }
    print("Successfully lexed " + int_to_string(count) + " tokens.\n")
    
    print("Step 2: Parsing test...\n")
    var simple_source = src_valid_main_program()
    var parser = make_parser(simple_source)
    var program = parser.parse_program()
    var statements = program.statements
    
    if parser.has_error {
        print("Parsing failed!\n")
        return 1
    }
    
    print("Successfully parsed " + int_to_string(statements.len()) + " statements.\n")
    var i = 0
    while i < statements.len() {
        print("AST[" + int_to_string(i) + "]: " + stmt_to_string(statements[i]) + "\n")
        i = i + 1
    }

    if !run_parser_frontend_steps() {
        return 1
    }

    print("Step 11: Name resolution smoke test...\n")
    var resolve_result = resolve_program(program)
    if resolve_result.has_error {
        print("Resolver failed unexpectedly on valid sample.\n")
        return 1
    }
    print("Resolver smoke test passed.\n")

    print("Step 11.5: Resolver declaration preload defensive tests...\n")
    var invalid_decl_program = make_program(vec![make_decl_base(DECL_UNKNOWN())], vec![])
    var invalid_decl_result = resolve_program(invalid_decl_program)
    if !invalid_decl_result.has_error {
        print("Resolver defensive test failed: DECL_UNKNOWN preload should report error.\n")
        return 1
    }
    print("Resolver defensive test passed: DECL_UNKNOWN preload reports error.\n")
    var mismatch_stmt = make_stmt_function(
        make_token(T_IDENTIFIER(), "foo", 1, 1),
        make_type_ref(TYPE_UNKNOWN(), "int"),
        vec![],
        vec![],
        vec![]
    )
    mismatch_stmt.decl.kind = DECL_STRUCT()
    if !has_decl_payload_mismatch(mismatch_stmt) {
        print("Decl payload mismatch defensive test failed: mismatch should be detected.\n")
        return 1
    }
    var mismatch_decl = stmt_to_decl(mismatch_stmt)
    if mismatch_decl.kind != DECL_UNKNOWN() {
        print("Decl payload mismatch defensive test failed: stmt_to_decl should return DECL_UNKNOWN.\n")
        return 1
    }
    print("Decl payload mismatch defensive test passed.\n")
    var sig_resolver = make_resolver()
    sig_resolver.preload_enum_variant_signature("Result", "Ok", vec![TYPE_UNKNOWN()], vec!["unknown"])
    sig_resolver.preload_enum_variant_signature("Result", "Ok", vec![TYPE_INT()], vec!["int"])
    if sig_resolver.lookup_enum_constructor_param_type("Ok", 0) != TYPE_INT() {
        print("Signature precedence test failed: latest enum payload type should win.\n")
        return 1
    }
    if sig_resolver.lookup_enum_constructor_param_type_name("Ok", 0) != "int" {
        print("Signature precedence test failed: latest enum payload type-name should win.\n")
        return 1
    }
    sig_resolver.function_signatures.push(
        make_function_signature("demo", TYPE_UNKNOWN(), vec![TYPE_UNKNOWN()], "unknown", vec!["unknown"], "")
    )
    sig_resolver.function_signatures.push(
        make_function_signature("demo", TYPE_INT(), vec![TYPE_INT()], "int", vec!["int"], "")
    )
    if sig_resolver.lookup_user_function_return_type("demo") != TYPE_INT() {
        print("Signature precedence test failed: latest function return type should win.\n")
        return 1
    }
    if sig_resolver.lookup_user_function_param_type("demo", 0) != TYPE_INT() {
        print("Signature precedence test failed: latest function param type should win.\n")
        return 1
    }
    sig_resolver.function_signatures.push(
        make_function_signature("demo_enum", TYPE_NAMED(), vec![], "Status", vec![], "")
    )
    sig_resolver.function_signatures.push(
        make_function_signature("demo_enum", TYPE_NAMED(), vec![], "Status", vec![], "Status")
    )
    if sig_resolver.lookup_user_function_return_enum_name("demo_enum") != "Status" {
        print("Signature precedence test failed: latest function return enum-name should win.\n")
        return 1
    }
    print("Signature precedence test passed.\n")

    print("Step 12: Name resolution negative tests...\n")
    if !expect_shared_resolve_error(src_resolver_undefined_in_initializer(), "undefined variable in initializer") {
        return 1
    }
    if !expect_shared_resolve_error(src_resolver_undefined_assignment(), "assignment to undefined variable") {
        return 1
    }
    if !expect_shared_resolve_error(src_resolver_duplicate_same_scope(), "duplicate variable in same scope") {
        return 1
    }
    if !expect_shared_resolve_error(src_resolver_out_of_scope_after_block(), "variable out of scope after block") {
        return 1
    }

    print("Step 13: Name resolution positive scope tests...\n")
    if !expect_shared_resolve_success(src_resolver_shadowing_ok(), "shadowing in inner block is legal") {
        return 1
    }

    print("Step 14: Function-like scope resolution tests...\n")
    var fn_params = vec!["p"]
    if !expect_shared_function_body_resolve_success(fn_params, src_resolver_function_body_ok(), "function-like scope resolution") {
        return 1
    }
    if !expect_shared_function_body_resolve_success(fn_params, src_resolver_function_body_if_else_return_ok(), "if-else guaranteed return is legal") {
        return 1
    }
    if !expect_shared_function_body_resolve_error(fn_params, src_resolver_function_body_missing_return(), "function body missing return") {
        return 1
    }
    if !expect_shared_function_body_resolve_error(fn_params, src_resolver_function_body_void_return_bad(), "void return in value-return function") {
        return 1
    }

    print("Step 15: Builtin call arity resolution tests...\n")
    if !expect_shared_resolve_success(src_resolver_builtin_arity_ok(), "builtin arity positive") {
        return 1
    }
    if !expect_shared_resolve_error(src_resolver_builtin_arity_bad(), "builtin arity mismatch negative") {
        return 1
    }

    print("Step 16: Type consistency resolution tests...\n")
    if !expect_shared_resolve_success(src_resolver_type_consistency_ok(), "type consistency positive") {
        return 1
    }
    if !expect_shared_resolve_error(src_resolver_type_assignment_bad(), "assignment type mismatch negative") {
        return 1
    }
    if !expect_shared_resolve_error(src_resolver_type_arithmetic_bad(), "arithmetic type mismatch negative") {
        return 1
    }
    if !expect_shared_resolve_error(src_resolver_type_logical_bad(), "logical type mismatch negative") {
        return 1
    }
    if !expect_shared_resolve_error(src_resolver_null_assignment_bad(), "null assignment mismatch negative") {
        return 1
    }
    if !expect_shared_resolve_error(src_resolver_null_arithmetic_bad(), "null arithmetic mismatch negative") {
        return 1
    }
    if !expect_shared_resolve_success(src_resolver_null_equality_ok(), "null equality positive") {
        return 1
    }

    print("Step 17: User function call arity resolution tests...\n")
    if !expect_shared_resolve_success(src_resolver_user_function_arity_ok(), "user function arity positive") {
        return 1
    }
    if !expect_shared_resolve_error(src_resolver_user_function_arity_bad(), "user function arity mismatch negative") {
        return 1
    }

    print("Step 18: User function type-signature resolution tests...\n")
    if !expect_shared_resolve_success(src_resolver_user_function_type_ok(), "user function type signature positive") {
        return 1
    }
    if !expect_shared_resolve_success(src_resolver_user_function_float_signature_ok(), "user function float signature positive") {
        return 1
    }
    if !expect_shared_resolve_success(src_resolver_nullable_signature_ok(), "nullable signature positive") {
        return 1
    }
    if !expect_shared_resolve_error(src_resolver_user_function_arg_type_bad(), "user function argument type mismatch negative") {
        return 1
    }
    if !expect_shared_resolve_error(src_resolver_user_function_return_type_bad(), "user function return type mismatch negative") {
        return 1
    }
    if !expect_shared_resolve_error(src_resolver_nullable_signature_bad(), "nullable signature return mismatch negative") {
        return 1
    }

    print("Step 19: Custom type signature resolution tests...\n")
    if !expect_shared_resolve_success(src_resolver_custom_type_signature_ok(), "custom type signature positive") {
        return 1
    }
    if !expect_shared_resolve_success(src_resolver_custom_nullable_signature_ok(), "custom nullable signature positive") {
        return 1
    }
    if !expect_shared_resolve_error(src_resolver_custom_type_signature_bad(), "custom type signature unknown type negative") {
        return 1
    }

    print("Step 20: Type declaration skeleton tests...\n")
    var struct_source = src_parser_struct_decl_program()
    var struct_parser = make_parser(struct_source)
    var struct_program = struct_parser.parse_program()
    if struct_parser.has_error {
        print("Type declaration parse failed unexpectedly.\n")
        return 1
    }
    if struct_program.statements.len() < 1 || !contains(stmt_to_string(struct_program.statements[0]), "(struct Boxed [") {
        print("Type declaration AST shape mismatch.\n")
        return 1
    }
    if !expect_shared_resolve_success(src_resolver_custom_type_signature_with_struct_ok(), "custom type signature with type declaration positive") {
        return 1
    }

    print("Step 21: Impl declaration skeleton tests...\n")
    var impl_source = src_parser_impl_decl_program()
    var impl_parser = make_parser(impl_source)
    var impl_program = impl_parser.parse_program()
    if impl_parser.has_error {
        print("Impl declaration parse failed unexpectedly.\n")
        return 1
    }
    if impl_program.statements.len() < 2 || !contains(stmt_to_string(impl_program.statements[1]), "(impl Boxed ") {
        print("Impl declaration AST shape mismatch.\n")
        return 1
    }
    if !expect_shared_resolve_success(src_resolver_custom_type_signature_with_impl_ok(), "custom type signature with impl declaration positive") {
        return 1
    }

    print("Step 22: Impl member function skeleton parsing tests...\n")
    var impl_method_source = src_parser_impl_method_decl_program()
    var impl_method_parser = make_parser(impl_method_source)
    var impl_method_program = impl_method_parser.parse_program()
    if impl_method_parser.has_error {
        print("Impl member function parse failed unexpectedly.\n")
        return 1
    }
    if impl_method_program.statements.len() < 2 {
        print("Impl member function AST size mismatch.\n")
        return 1
    }
    var impl_ast = stmt_to_string(impl_method_program.statements[1])
    if !contains(impl_ast, "(impl Boxed ") || !contains(impl_ast, "(func value/0") {
        print("Impl member function AST shape mismatch.\n")
        return 1
    }

    print("Step 23: Impl semantic resolution tests...\n")
    if !expect_shared_resolve_success(src_resolver_impl_methods_ok(), "impl method semantic positive") {
        return 1
    }
    if !expect_shared_resolve_error(src_resolver_impl_unknown_type_bad(), "impl unknown target type negative") {
        return 1
    }
    if !expect_shared_resolve_error(src_resolver_impl_duplicate_method_bad(), "impl duplicate method negative") {
        return 1
    }

    if !run_function_signature_typeref_tests() {
        return 1
    }

    if !run_struct_field_declaration_tests() {
        return 1
    }
    if !run_const_declaration_tests() {
        return 1
    }
    if !run_import_extern_declaration_tests() {
        return 1
    }
    if !run_enum_declaration_tests() {
        return 1
    }
    if !run_match_and_enum_payload_tests() {
        return 1
    }

    print("Tests completed successfully.\n")
    return 0
}
