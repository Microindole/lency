// tests/example/selfhost/driver/steps/match_expr.lcy
// Match syntax and payload parsing checks.

import std.core
import std.fs
import std.str
import tests.example.selfhost.driver.test_cases
import tests.example.selfhost.driver.test_support
import lencyc.syntax.parser
import lencyc.syntax.ast

string read_match_case_or_empty(string path) {
    var source_res = read_to_string(path)
    if source_res.is_err() {
        print("Failed to read test case: " + path + "\n")
        return ""
    }
    return source_res.unwrap()
}

bool run_match_and_enum_payload_tests() {
    print("Step 29: Match syntax and payload parsing tests...\n")

    var enum_source = read_match_case_or_empty("tests/example/parser/enum_payload_decl.lcy")
    if enum_source == "" {
        return false
    }
    var enum_parser = make_parser(enum_source)
    var enum_program = enum_parser.parse_program()
    if enum_parser.has_error {
        print("Enum payload declaration parse failed unexpectedly.\n")
        return false
    }
    if enum_program.statements.len() < 1 || enum_program.statements[0].kind != STMT_ENUM() {
        print("Enum payload declaration AST kind mismatch.\n")
        return false
    }
    var enum_decl = stmt_to_decl(enum_program.statements[0])
    if enum_decl.enum_variants.len() != 3 {
        print("Enum payload variant count mismatch.\n")
        return false
    }
    if enum_decl.enum_variants[1].name != "Text" || enum_decl.enum_variants[1].payload_types.len() != 1 {
        print("Enum payload variant #2 mismatch.\n")
        return false
    }
    if enum_decl.enum_variants[1].payload_types[0].name != "string" {
        print("Enum payload variant #2 type mismatch.\n")
        return false
    }
    if enum_decl.enum_variants[2].name != "Pair" || enum_decl.enum_variants[2].payload_types.len() != 2 {
        print("Enum payload variant #3 mismatch.\n")
        return false
    }
    if !contains(stmt_to_string(enum_program.statements[0]), "(enum Message [Quit, Text(string), Pair(int, string)])") {
        print("Enum payload declaration AST shape mismatch.\n")
        return false
    }

    var match_source = read_match_case_or_empty("tests/example/parser/match_expr.lcy")
    if match_source == "" {
        return false
    }
    var match_parser = make_parser(match_source)
    var match_program = match_parser.parse_program()
    if match_parser.has_error {
        print("Match expression parse failed unexpectedly.\n")
        return false
    }
    if match_program.statements.len() < 2 || match_program.statements[1].kind != STMT_VAR_DECL() {
        print("Match expression AST kind mismatch.\n")
        return false
    }
    var match_expr = match_program.statements[1].expr
    if match_expr.kind != EXPR_MATCH() {
        print("Match expression AST node kind mismatch.\n")
        return false
    }
    if match_expr.arm_patterns.len() != 3 {
        print("Match expression arm count mismatch.\n")
        return false
    }
    if !contains(stmt_to_string(match_program.statements[1]), "(var y = (match x {0 => 10, 1 => 20, _ => 30}))") {
        print("Match expression AST shape mismatch.\n")
        return false
    }
    var literal_pattern_source = read_match_case_or_empty("tests/example/parser/match_literal_pattern.lcy")
    if literal_pattern_source == "" {
        return false
    }
    var literal_pattern_parser = make_parser(literal_pattern_source)
    var literal_pattern_program = literal_pattern_parser.parse_program()
    if literal_pattern_parser.has_error {
        print("Match literal pattern parse failed unexpectedly.\n")
        return false
    }
    if literal_pattern_program.statements.len() < 3 || literal_pattern_program.statements[1].kind != STMT_VAR_DECL() {
        print("Match literal pattern AST kind mismatch.\n")
        return false
    }
    if !contains(stmt_to_string(literal_pattern_program.statements[1]), "(var y = (match x {\"ok\" => 1, \"no\" => 0, _ => 2}))") {
        print("Match literal pattern AST shape mismatch.\n")
        return false
    }
    if !contains(stmt_to_string(literal_pattern_program.statements[2]), "(var z = (match null {null => 1, _ => 0}))") {
        print("Match null literal pattern AST shape mismatch.\n")
        return false
    }
    var guard_pattern_source = read_match_case_or_empty("tests/example/parser/match_guard_pattern.lcy")
    if guard_pattern_source == "" {
        return false
    }
    var guard_pattern_parser = make_parser(guard_pattern_source)
    var guard_pattern_program = guard_pattern_parser.parse_program()
    if guard_pattern_parser.has_error {
        print("Match guard pattern parse failed unexpectedly.\n")
        return false
    }
    if guard_pattern_program.statements.len() < 3 || guard_pattern_program.statements[2].kind != STMT_VAR_DECL() {
        print("Match guard pattern AST kind mismatch.\n")
        return false
    }
    var guard_stmt_str = stmt_to_string(guard_pattern_program.statements[2])
    if !contains(guard_stmt_str, "(var y = (match m {Quit => 0, Text(v) if ") ||
       !contains(guard_stmt_str, "=> 1, Text(v) => 2}))") {
        print("Match guard pattern AST shape mismatch.\n")
        return false
    }

    var bad_match_source = read_match_case_or_empty("tests/example/parser/match_missing_arrow_bad.lcy")
    if bad_match_source == "" {
        return false
    }
    if !expect_shared_parse_error(bad_match_source, "match missing '=>'") {
        return false
    }
    var bad_guard_source = read_match_case_or_empty("tests/example/parser/match_guard_missing_paren_bad.lcy")
    if bad_guard_source == "" {
        return false
    }
    if !expect_shared_parse_error(bad_guard_source, "match guard missing parentheses") {
        return false
    }
    if !expect_shared_resolve_success(match_source, "match resolver smoke positive") {
        return false
    }
    var payload_pattern_source = read_match_case_or_empty("tests/example/parser/match_payload_pattern.lcy")
    if payload_pattern_source == "" {
        return false
    }
    var payload_pattern_parser = make_parser(payload_pattern_source)
    var payload_pattern_program = payload_pattern_parser.parse_program()
    if payload_pattern_parser.has_error {
        print("Match payload pattern parse failed unexpectedly.\n")
        return false
    }
    if payload_pattern_program.statements.len() < 3 || payload_pattern_program.statements[2].kind != STMT_VAR_DECL() {
        print("Match payload pattern AST kind mismatch.\n")
        return false
    }
    if !contains(stmt_to_string(payload_pattern_program.statements[2]), "(var y = (match m {Quit => 0, Text(msg) => 1, Pair(a, b) => a}))") {
        print("Match payload pattern AST shape mismatch.\n")
        return false
    }
    var nested_payload_pattern_source = read_match_case_or_empty("tests/example/parser/match_payload_nested_pattern.lcy")
    if nested_payload_pattern_source == "" {
        return false
    }
    var nested_payload_pattern_parser = make_parser(nested_payload_pattern_source)
    var nested_payload_pattern_program = nested_payload_pattern_parser.parse_program()
    if nested_payload_pattern_parser.has_error {
        print("Match nested payload pattern parse failed unexpectedly.\n")
        return false
    }
    if nested_payload_pattern_program.statements.len() < 4 || nested_payload_pattern_program.statements[3].kind != STMT_VAR_DECL() {
        print("Match nested payload pattern AST kind mismatch.\n")
        return false
    }
    if !contains(stmt_to_string(nested_payload_pattern_program.statements[3]), "(var y = (match m {Quit => 0, Wrap(Num(v)) => v, Wrap(Text(msg)) => 1}))") {
        print("Match nested payload pattern AST shape mismatch.\n")
        return false
    }
    if !expect_shared_resolve_success(src_resolver_enum_match_exhaustive_ok(), "enum match exhaustive positive") {
        return false
    }
    if !expect_shared_resolve_error(src_resolver_enum_match_non_exhaustive_bad(), "enum match non-exhaustive negative") {
        return false
    }
    if !expect_shared_resolve_error(src_resolver_enum_match_duplicate_pattern_bad(), "enum match duplicate pattern negative") {
        return false
    }
    if !expect_shared_resolve_error(src_resolver_enum_match_unknown_variant_bad(), "enum match unknown variant negative") {
        return false
    }
    if !expect_shared_resolve_success(src_resolver_enum_payload_ctor_type_ok(), "enum payload constructor type positive") {
        return false
    }
    if !expect_shared_resolve_error(src_resolver_enum_payload_ctor_type_bad(), "enum payload constructor type mismatch negative") {
        return false
    }
    if !expect_shared_resolve_error(src_resolver_enum_payload_ctor_arity_bad(), "enum payload constructor arity mismatch negative") {
        return false
    }
    if !expect_shared_resolve_success(src_resolver_enum_payload_match_bind_ok(), "enum payload match binder positive") {
        return false
    }
    if !expect_shared_resolve_error(src_resolver_enum_payload_match_bind_arity_bad(), "enum payload match binder arity mismatch negative") {
        return false
    }
    if !expect_shared_resolve_error(src_resolver_enum_payload_match_bind_type_bad(), "enum payload match binder type mismatch negative") {
        return false
    }
    if !expect_shared_resolve_error(src_resolver_enum_payload_match_bind_duplicate_bad(), "enum payload match binder duplicate negative") {
        return false
    }
    if !expect_shared_resolve_success(src_resolver_enum_payload_match_nested_ok(), "enum payload nested pattern positive") {
        return false
    }
    if !expect_shared_resolve_error(src_resolver_enum_payload_match_nested_unknown_variant_bad(), "enum payload nested pattern unknown variant negative") {
        return false
    }
    if !expect_shared_resolve_error(src_resolver_enum_payload_match_nested_arity_bad(), "enum payload nested pattern arity negative") {
        return false
    }
    if !expect_shared_resolve_success(src_resolver_enum_flow_function_return_ok(), "enum flow function return positive") {
        return false
    }
    if !expect_shared_resolve_success(src_resolver_enum_flow_match_result_ok(), "enum flow match result positive") {
        return false
    }
    if !expect_shared_resolve_success(src_resolver_enum_flow_match_assign_target_ok(), "enum flow match assign-target positive") {
        return false
    }
    if !expect_shared_resolve_error(src_resolver_enum_flow_match_assign_target_non_exhaustive_bad(), "enum flow match assign-target non-exhaustive negative") {
        return false
    }
    if !expect_shared_resolve_success(src_resolver_enum_flow_multi_call_chain_ok(), "enum flow multi-call chain positive") {
        return false
    }
    if !expect_shared_resolve_error(src_resolver_enum_flow_multi_call_chain_mismatch_bad(), "enum flow multi-call chain mismatch negative") {
        return false
    }
    if !expect_shared_resolve_success(src_resolver_enum_flow_grouped_callee_chain_ok(), "enum flow grouped-callee chain positive") {
        return false
    }
    if !expect_shared_resolve_error(src_resolver_enum_flow_grouped_callee_chain_mismatch_bad(), "enum flow grouped-callee chain mismatch negative") {
        return false
    }
    if !expect_shared_resolve_success(src_resolver_non_enum_match_literal_ok(), "non-enum match literal positive") {
        return false
    }
    if !expect_shared_resolve_success(src_resolver_non_enum_match_char_literal_ok(), "non-enum match char literal positive") {
        return false
    }
    if !expect_shared_resolve_error(src_resolver_non_enum_match_literal_type_mismatch_bad(), "non-enum match literal type mismatch negative") {
        return false
    }
    if !expect_shared_resolve_error(src_resolver_non_enum_match_identifier_pattern_bad(), "non-enum match identifier pattern negative") {
        return false
    }
    if !expect_shared_resolve_success(src_resolver_match_guard_bool_ok(), "match guard bool positive") {
        return false
    }
    if !expect_shared_resolve_error(src_resolver_match_guard_non_bool_bad(), "match guard non-bool negative") {
        return false
    }
    if !expect_shared_resolve_success(src_resolver_enum_match_guard_binder_ok(), "enum match guard binder positive") {
        return false
    }
    if !expect_shared_resolve_error(src_resolver_enum_match_guard_non_exhaustive_bad(), "enum match guard non-exhaustive negative") {
        return false
    }
    if !expect_shared_resolve_error(src_resolver_enum_match_guard_non_bool_bad(), "enum match guard non-bool negative") {
        return false
    }
    if !expect_shared_resolve_error(src_resolver_enum_flow_assignment_mismatch_bad(), "enum flow assignment mismatch negative") {
        return false
    }
    return true
}
